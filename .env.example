# PostgreSQL
POSTGRES_DB=tcg_tracker
POSTGRES_USER=tcg_user
POSTGRES_PASSWORD=changeme

# PokéWallet API
POKEWALLET_API_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cache TTLs
PRICE_CACHE_TTL_HOURS=24
SET_CACHE_TTL_DAYS=7

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme

# Authentication (optional — leave unset to disable auth entirely)
# When AUTH_USERNAME is not set, all endpoints are publicly writable.
# AUTH_PASSWORD can be a plaintext string or a bcrypt hash ($2b$...).
# JWT_SECRET_KEY should be a random hex string; one is auto-generated per
# container restart if omitted (tokens become invalid on restart).
#AUTH_USERNAME=admin
#AUTH_PASSWORD=changeme
#JWT_SECRET_KEY=change-me-to-a-long-random-hex-string
